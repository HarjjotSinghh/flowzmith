    },
    {
      "id": "flow_auto",
      "name": "Automated Flow Workflow",
      "description": "Generate, create MCP server, and deploy to Flow",
      "icon": "Zap",
      "category": "flow",
      "requiresInput": true,
      "endpoint": "/api/flow/auto",
      "method": "POST",
      "steps": [
        {
          "id": "auto_workflow",
          "title": "Automated Workflow",
          "description": "This will handle the complete workflow automatically",
          "fields": [
            {
              "name": "requirements",
              "label": "Contract Requirements",
              "type": "textarea",
              "required": true,
              "placeholder": "Describe your contract..."
            }
          ]
        }
      ]
    },
    {
      "id": "mcp_explorer",
      "name": "MCP Explorer",
      "description": "Explore Flow blockchain using MCP",
      "icon": "Compass",
      "category": "flow",
      "requiresInput": false,
      "endpoint": null
    },
    {
      "id": "chat",
      "name": "Chat Assistant",
      "description": "Chat with AI assistant for guidance",
      "icon": "MessageSquare",
      "category": "chat",
      "requiresInput": false,
      "endpoint": null,
      "redirectTo": "/chat"
    }
  ],
