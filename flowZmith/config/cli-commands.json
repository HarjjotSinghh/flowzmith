      "endpoint": null
    },
    {
      "id": "flow_init",
      "name": "Initialize Flow Project",
      "description": "Initialize a new Flow project",
      "icon": "FolderPlus",
      "category": "flow",
      "requiresInput": false,
      "endpoint": "/api/flow/init",
      "method": "POST",
      "steps": [
        {
          "id": "project_init",
          "title": "Project Initialization",
          "fields": [
            {
              "name": "name",
              "label": "Project Name (optional)",
              "type": "text",
              "required": false,
              "placeholder": "Auto-generated if not provided"
            }
          ]
        }
      ]
    },
    {
      "id": "flow_deploy",
      "name": "Deploy Flow Contract",
      "description": "Deploy contracts in a Flow project",
      "icon": "Rocket",
      "category": "flow",
      "requiresInput": true,
      "endpoint": "/api/flow/deploy",
      "method": "POST"
    },
    {
      "id": "flow_status",
      "name": "Flow Project Status",
      "description": "Get status information for a Flow project",
      "icon": "Info",
      "category": "flow",
      "requiresInput": true,
      "endpoint": "/api/flow/status",
      "method": "GET"
    },
    {
      "id": "flow_list",
      "name": "List Flow Projects",
