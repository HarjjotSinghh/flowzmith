{
  "version": "1.0.0",
  "commands": [
    {
      "id": "setup",
      "name": "Setup",
      "description": "Setup and verify the development environment",
      "icon": "Settings",
      "category": "system",
      "requiresInput": false,
      "endpoint": null
    },
    {
      "id": "create_contract",
      "name": "Create Contract",
      "description": "Create a new smart contract with step-by-step guidance",
      "icon": "FileCode",
      "category": "contract",
      "requiresInput": true,
      "endpoint": "/api/contracts/submit",
      "method": "POST",
      "steps": [
        {
          "id": "basic_info",
          "title": "Basic Contract Information",
          "description": "Provide basic information about your contract",
          "fields": [
            {
              "name": "contract_name",
              "label": "Contract Name",
              "type": "text",
              "required": true,
              "placeholder": "e.g., UserProfiles, TokenContract, NFTMarketplace",
              "helpText": "Choose a descriptive name for your contract"
            },
            {
              "name": "contract_type",
              "label": "Contract Type",
              "type": "select",
              "required": true,
              "options": [
                { "label": "Custom", "value": "custom" },
                { "label": "Token", "value": "token" },
                { "label": "NFT", "value": "nft" },
                { "label": "Marketplace", "value": "marketplace" },
                { "label": "DAO", "value": "dao" },
                { "label": "DeFi", "value": "defi" }
              ],
              "defaultValue": "custom",
              "helpText": "Select the type that best describes your contract"
            }
          ]
        },
        {
          "id": "requirements",
          "title": "Contract Requirements",
          "description": "Describe what your contract should do",
          "fields": [
            {
              "name": "description",
              "label": "Contract Description",
              "type": "textarea",
              "required": true,
              "placeholder": "Describe your smart contract requirements in detail...",
              "helpText": "Be specific about the functionality, features, and behavior you need"
            },
            {
              "name": "network",
              "label": "Target Network",
              "type": "select",
              "required": true,
              "options": [
                { "label": "Emulator", "value": "emulator" },
                { "label": "Testnet", "value": "testnet" },
                { "label": "Mainnet", "value": "mainnet" }
              ],
              "defaultValue": "testnet",
              "helpText": "Choose the network where you plan to deploy"
            }
          ]
        },
        {
          "id": "configuration",
          "title": "Project Configuration",
          "description": "Configure additional project settings",
          "fields": [
            {
              "name": "account_setup",
              "label": "Account Setup",
              "type": "select",
              "required": true,
              "options": [
                { "label": "Single Account", "value": "single" },
                { "label": "Multiple Accounts", "value": "multiple" }
              ],
              "defaultValue": "single",
              "helpText": "Choose how many accounts your contract will use"
            },
            {
              "name": "include_transactions",
              "label": "Include Transaction Scripts",
              "type": "checkbox",
              "required": false,
              "defaultValue": true,
              "helpText": "Generate transaction scripts for interacting with your contract"
            },
            {
              "name": "include_deployment",
              "label": "Include Deployment Scripts",
              "type": "checkbox",
              "required": false,
              "defaultValue": true,
              "helpText": "Generate deployment scripts for easy contract deployment"
            },
            {
              "name": "include_tests",
              "label": "Include Test Cases",
              "type": "checkbox",
              "required": false,
              "defaultValue": true,
              "helpText": "Generate test cases to verify your contract functionality"
            }
          ]
        }
      ]
    },
    {
      "id": "deploy_contract",
      "name": "Deploy Contract",
      "description": "Deploy a smart contract to the blockchain",
      "icon": "Rocket",
      "category": "deployment",
      "requiresInput": true,
      "endpoint": "/api/deployments/deploy",
      "method": "POST",
      "steps": [
        {
          "id": "deployment_config",
          "title": "Deployment Configuration",
          "fields": [
            {
              "name": "contract_name",
              "label": "Contract Name",
              "type": "text",
              "required": true,
              "placeholder": "MyContract"
            },
            {
              "name": "network",
              "label": "Network",
              "type": "select",
              "required": true,
              "options": [
                { "label": "Emulator", "value": "emulator" },
                { "label": "Testnet", "value": "testnet" },
                { "label": "Mainnet", "value": "mainnet" }
              ]
            },
            {
              "name": "auto_deploy",
              "label": "Auto Deploy",
              "type": "checkbox",
              "required": false,
              "defaultValue": true
            }
          ]
        }
      ]
    },
    {
      "id": "generate_from_context",
      "name": "Generate from Context",
      "description": "Generate a contract using local markdown context",
      "icon": "Sparkles",
      "category": "contract",
      "requiresInput": true,
      "endpoint": "/api/contract/generate/stream",
      "method": "POST",
      "streaming": true,
      "steps": [
        {
          "id": "context_generation",
          "title": "Context-Based Generation",
          "fields": [
            {
              "name": "requirements",
              "label": "Contract Requirements",
              "type": "textarea",
              "required": true,
              "placeholder": "Describe the contract you want to build..."
            },
            {
              "name": "context_dir",
              "label": "Context Directory",
              "type": "text",
              "required": false,
              "placeholder": "context",
              "defaultValue": "context"
            },
            {
              "name": "network",
              "label": "Network",
              "type": "select",
              "required": true,
              "options": [
                { "label": "Emulator", "value": "emulator" },
                { "label": "Testnet", "value": "testnet" },
                { "label": "Mainnet", "value": "mainnet" }
              ]
            },
            {
              "name": "auto_deploy",
              "label": "Auto Deploy",
              "type": "checkbox",
              "required": false,
              "defaultValue": false
            }
          ]
        }
      ]
    },
    {
      "id": "search_docs",
      "name": "Search Documentation",
      "description": "Search documentation and knowledge base",
      "icon": "Search",
      "category": "documentation",
      "requiresInput": true,
      "endpoint": "/api/documentation/search",
      "method": "POST",
      "steps": [
        {
          "id": "search",
          "title": "Search Query",
          "fields": [
            {
              "name": "query",
              "label": "Search Query",
              "type": "text",
              "required": true,
              "placeholder": "Enter your search query..."
            },
            {
              "name": "limit",
              "label": "Results Limit",
              "type": "number",
              "required": false,
              "defaultValue": 20
            }
          ]
        }
      ]
    },
    {
      "id": "upload_docs",
      "name": "Upload Documentation",
      "description": "Upload documentation to the knowledge base",
      "icon": "Upload",
      "category": "documentation",
      "requiresInput": true,
      "endpoint": "/api/documentation/upload",
      "method": "POST"
    },
    {
      "id": "browse_docs",
      "name": "Browse Documentation",
      "description": "Browse documentation by categories",
      "icon": "FolderOpen",
      "category": "documentation",
      "requiresInput": false,
      "endpoint": "/api/documentation/categories",
      "method": "GET"
    },
    {
      "id": "crawl_docs",
      "name": "Crawl Documentation",
      "description": "Crawl and index external documentation sources",
      "icon": "Globe",
      "category": "documentation",
      "requiresInput": true,
      "endpoint": "/api/documentation/crawl",
      "method": "POST"
    },
    {
      "id": "firecrawl_search",
      "name": "Firecrawl Search",
      "description": "Interactive Firecrawl documentation search",
      "icon": "Search",
      "category": "documentation",
      "requiresInput": true,
      "endpoint": "/api/documentation/firecrawl/search",
      "method": "POST"
    },
    {
      "id": "list_deployments",
      "name": "List Deployments",
      "description": "View all contract deployments",
      "icon": "History",
      "category": "deployment",
      "requiresInput": false,
      "endpoint": "/api/deployments",
      "method": "GET"
    },
    {
      "id": "status",
      "name": "System Status",
      "description": "Check system status and statistics",
      "icon": "Activity",
      "category": "system",
      "requiresInput": false,
      "endpoint": "/api/system/status",
      "method": "GET"
    },
    {
      "id": "wizard",
      "name": "Contract Wizard",
      "description": "Complete contract creation wizard",
      "icon": "Wand2",
      "category": "contract",
