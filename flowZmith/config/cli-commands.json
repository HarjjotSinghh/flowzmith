      "category": "flow",
      "requiresInput": false,
      "endpoint": "/api/flow/projects",
      "method": "GET"
    },
    {
      "id": "flow_generate_deploy",
      "name": "Generate & Deploy",
      "description": "Generate and deploy a contract automatically",
      "icon": "Zap",
      "category": "flow",
