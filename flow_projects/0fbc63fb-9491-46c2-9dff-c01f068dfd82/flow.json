{
  "contracts": {
    "DigitalArtNFT": {
      "source": "./DigitalArtNFT.cdc",
      "aliases": {
        "testnet": "0x[testnet-deployment-address]",
        "mainnet": "0x[mainnet-deployment-address]"
      }
    },
    "FungibleToken": {
      "source": "./FungibleToken.cdc",
      "aliases": {
        "testnet": "0x9a0766d93b6608b7",
        "mainnet": "0xf233dcee88fe0abe"
      }
    },
    "NonFungibleToken": {
      "source": "./NonFungibleToken.cdc",
      "aliases": {
        "testnet": "0x631e88ae7f3c7bc9",
        "mainnet": "0x1d7e57aa55817448"
      }
    }
  },
  "networks": {
    "testnet": {
      "host": "access.devnet.nodes.onflow.org",
      "port": 9000
    },
    "mainnet": {
      "host": "access.mainnet.nodes.onflow.org",
      "port": 9000
    }
  },
  "accounts": {
    "testnet-account": {
      "address": "0x[testnet-deployment-address]",
      "key": {
        "type": "file",
        "location": "./testnet-private-key.json"
      }
    },
    "mainnet-account": {
      "address": "0x[mainnet-deployment-address]",
      "key": {
        "type": "file",
        "location": "./mainnet-private-key.json"
      }
    }
  },
  "deployments": {
    "testnet": [
      {
        "account": "testnet-account",
        "contracts": [
          "DigitalArtNFT"
        ]
      }
    ],
    "mainnet": [
      {
        "account": "mainnet-account",
        "contracts": [
          "DigitalArtNFT"
        ]
      }
    ]
  }
}