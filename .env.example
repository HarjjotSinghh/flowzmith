# Environment configuration for Flowzmith

# Application Settings
APP_NAME=Flowzmith
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database Configuration
DATABASE_URL=sqlite:///./smart_contract_llm.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/smart_contract_llm

# LLM Provider Configuration
# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# Groq Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama2-70b-4096
GROQ_BASE_URL=https://api.groq.com

# Preferred LLM Provider
PREFERRED_PROVIDER=OPENAI

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Flow Blockchain Configuration
FLOW_CLI_PATH=flow
FLOW_PROJECTS_PATH=./flow_projects
FLOW_NETWORK=testnet

# Security Settings
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Storage Settings
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10MB

# Vector Database Settings
ENABLE_VECTOR_SEARCH=true
VECTOR_DB_PATH=./vector_db
CHROMA_DB_PERSIST=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_PATH=./logs
ENABLE_REQUEST_LOGGING=true

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@smartcontractllm.com

# Analytics and Monitoring
ENABLE_ANALYTICS=false
ANALYTICS_ID=your_analytics_id

# Data Privacy Settings
DEFAULT_RETENTION_PERIOD=ONE_YEAR
AUTO_CLEANUP_ENABLED=true
CLEANUP_INTERVAL_HOURS=24

# Rate Limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# CORS Settings
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
ALLOWED_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
ALLOWED_HEADERS=["*"]

# WebSocket Settings
WS_MAX_CONNECTIONS=1000
WS_MESSAGE_SIZE_LIMIT=1048576  # 1MB
WS_PING_INTERVAL=30