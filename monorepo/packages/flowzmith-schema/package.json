{
  "name": "@flowzmith/schema",
  "version": "0.0.1",
  "description": "Shared schema definitions for Flowzmith CLI and Frontend",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./python": "./python/schema.py"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "generate-python": "node scripts/generate-python.js"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
