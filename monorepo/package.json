{
  "name": "next-forge",
  "version": "5.0.4",
  "bin": {
    "next-forge": "dist/index.js"
  },
  "files": [
    "dist/index.js"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "ultracite lint",
    "format": "ultracite format",
    "test": "turbo test",
    "test:watch": "turbo test --watch",
    "test:coverage": "turbo test --coverage",
    "analyze": "turbo analyze",
    "translate": "turbo translate",
    "boundaries": "turbo boundaries",
    "typecheck": "turbo typecheck",
    "bump-deps": "npx npm-check-updates --deep -u -x react-day-picker",
    "bump-ui": "npx shadcn@latest add --all --overwrite -c packages/design-system",
    "migrate": "cd packages/database && npx prisma format && npx prisma generate && npx prisma db push",
    "db:generate": "cd packages/database && npx prisma generate",
    "db:push": "cd packages/database && npx prisma db push",
    "db:studio": "cd packages/database && npx prisma studio",
    "clean": "git clean -xdf node_modules",
    "clean:all": "turbo clean && git clean -xdf node_modules .turbo",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build --filter=!@repo/* && changeset publish"
  },
  "devDependencies": {
    "@auto-it/first-time-contributor": "^11.3.0",
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "^2.27.10",
    "@repo/typescript-config": "*",
    "@turbo/gen": "^2.5.3",
    "@types/node": "^22.15.21",
    "@types/react": "19.1.5",
    "@types/react-dom": "19.1.5",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.7",
    "tsup": "^8.5.0",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3",
    "ultracite": "^4.2.5",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/next-forge.git"
  },
  "keywords": [
    "nextjs",
    "monorepo",
    "turbo",
    "typescript",
    "react",
    "tailwindcss"
  ],
  "author": "Your Name",
  "license": "MIT",
  "packageManager": "bun@1.1.43",
  "dependencies": {
    "@arcjet/next": "1.0.0-beta.7",
    "@clack/prompts": "^0.11.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@sentry/nextjs": "^9.22.0",
    "@t3-oss/env-nextjs": "^0.13.4",
    "commander": "^14.0.0",
    "date-fns": "^4.1.0",
    "fumadocs-core": "^15.4.0",
    "fuse.js": "^7.1.0",
    "import-in-the-middle": "^1.13.2",
    "lucide-react": "^0.511.0",
    "mdx-bundler": "^10.1.1",
    "next": "15.3.2",
    "next-themes": "^0.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "require-in-the-middle": "^7.5.2",
    "sharp": "^0.34.2",
    "shiki": "^3.4.2",
    "zod": "^3.25.28"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
